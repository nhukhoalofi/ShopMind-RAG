APP_NAME=ShopMind RAG API
APP_ENV=development

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shopmind_chunks

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

GROQ_API_KEY=your_key_here
